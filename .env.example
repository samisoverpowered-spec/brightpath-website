# ===================== STRIPE =====================
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — generated when you create a webhook endpoint in Stripe dashboard
# For local testing: use `stripe listen --forward-to localhost:3000/api/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...

# ===================== RESEND =====================
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# ===================== APP =====================
# Your live site URL (no trailing slash). For local dev use http://localhost:3000
BASE_URL=https://yourdomain.com

# Port for local development
PORT=3000
